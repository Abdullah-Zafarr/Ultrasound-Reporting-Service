NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPER_ADMIN_EMAIL=admin@example.com
DEVELOPER_PORTAL_USERNAME=developer_portal_username
DEVELOPER_PORTAL_PASSWORD=developer_portal_password
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
GLADIA_API_KEY=your_gladia_api_key
NEXT_PUBLIC_DICOMWEB_API_URL=https://your-dicomweb-server
NEXT_PUBLIC_HL7_EXPORT_API_URL=https://your-hl7-export-endpoint
NEXT_PUBLIC_REPORT_API_URL=https://your-report-api-endpoint

# Optional (local dev only): bypass Supabase auth/UI login.
# Default is off; turning it on can hide real RLS issues.
NEXT_PUBLIC_DEV_BYPASS_AUTH=false
